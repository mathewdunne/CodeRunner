{
	"title": "CodeRunner — Control Plane HTTP",
	"uid": "coderunner-http",
	"tags": ["frc-sim"],
	"schemaVersion": 38,
	"version": 1,
	"editable": true,
	"refresh": "30s",
	"time": { "from": "now-1h", "to": "now" },
	"timepicker": {},
	"templating": {
		"list": [
			{
				"name": "datasource",
				"type": "datasource",
				"query": "prometheus",
				"label": "Data source",
				"hide": 0,
				"refresh": 1,
				"current": {}
			}
		]
	},
	"panels": [
		{
			"id": 1,
			"type": "timeseries",
			"title": "Request rate by route (req/s)",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "sum by (route) (rate(http_request_duration_seconds_count[5m]))",
					"legendFormat": "{{route}}",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 10,
						"lineInterpolation": "linear"
					}
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "list",
					"placement": "bottom",
					"showLegend": true
				},
				"tooltip": { "mode": "multi", "sort": "desc" }
			}
		},
		{
			"id": 2,
			"type": "timeseries",
			"title": "Requests in flight",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "http_requests_in_flight",
					"legendFormat": "in flight",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 20 }
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "list",
					"placement": "bottom",
					"showLegend": true
				},
				"tooltip": { "mode": "single" }
			}
		},
		{
			"id": 3,
			"type": "timeseries",
			"title": "p95 latency by route",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
					"legendFormat": "{{route}}",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"custom": { "drawStyle": "line", "fillOpacity": 5 }
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "list",
					"placement": "bottom",
					"showLegend": true
				},
				"tooltip": { "mode": "multi", "sort": "desc" }
			}
		},
		{
			"id": 4,
			"type": "timeseries",
			"title": "Overall latency quantiles",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
					"legendFormat": "p50",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				},
				{
					"refId": "B",
					"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
					"legendFormat": "p95",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				},
				{
					"refId": "C",
					"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
					"legendFormat": "p99",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "list",
					"placement": "bottom",
					"showLegend": true
				},
				"tooltip": { "mode": "multi" }
			}
		},
		{
			"id": 5,
			"type": "stat",
			"title": "5xx error rate",
			"gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "sum(rate(http_request_duration_seconds_count{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count[5m])), 0.0001)",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 0.01 },
							{ "color": "red", "value": 0.05 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "background",
				"graphMode": "area"
			}
		},
		{
			"id": 6,
			"type": "stat",
			"title": "Total req/s",
			"gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "sum(rate(http_request_duration_seconds_count[5m]))",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "area"
			}
		},
		{
			"id": 7,
			"type": "table",
			"title": "Top 10 slowest routes (p95, 10m)",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
			"datasource": { "type": "prometheus", "uid": "${datasource}" },
			"targets": [
				{
					"refId": "A",
					"expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[10m]))))",
					"instant": true,
					"format": "table",
					"datasource": { "type": "prometheus", "uid": "${datasource}" }
				}
			],
			"fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
			"options": { "showHeader": true }
		}
	]
}
