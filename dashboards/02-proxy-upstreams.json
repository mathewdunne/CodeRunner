{
  "title": "CodeRunner — Proxy Upstreams",
  "uid": "coderunner-proxy",
  "tags": ["frc-sim"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "templating": {
    "list": [
      {"name": "datasource", "type": "datasource", "query": "prometheus", "label": "Data source", "hide": 0, "refresh": 1, "current": {}}
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Upstream call rate by outcome",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "sum by (upstream, outcome) (rate(proxy_upstream_duration_seconds_count[5m]))", "legendFormat": "{{upstream}} / {{outcome}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 upstream latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, upstream) (rate(proxy_upstream_duration_seconds_bucket[5m])))", "legendFormat": "{{upstream}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 5}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Failure ratio per upstream",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "sum by (upstream) (rate(proxy_upstream_duration_seconds_count{outcome!=\"ok\"}[5m])) / clamp_min(sum by (upstream) (rate(proxy_upstream_duration_seconds_count[5m])), 0.0001)", "legendFormat": "{{upstream}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"drawStyle": "line", "fillOpacity": 15}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p99 upstream latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.99, sum by (le, upstream) (rate(proxy_upstream_duration_seconds_bucket[5m])))", "legendFormat": "{{upstream}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 5}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    }
  ]
}
