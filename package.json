{
  "name": "frc-programming-training-sim",
  "private": true,
  "version": "1.0.0-v1.0",
  "description": "V1 rewrite scaffold for the FRC Web Simulator.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:control": "bun apps/control/src/main.ts",
    "dev:web": "bun run --cwd apps/web dev",
    "build:web": "bun run --cwd apps/web build",
    "apply:ascope-patches": "bun scripts/apply-ascope-patches.ts",
    "build:ascope": "bun scripts/build-ascope-lite.ts",
    "verify:ascope": "bun scripts/verify-ascope.ts",
    "docker:build:sim": "bun scripts/build-sim-image.ts",
    "docker:build:lsp": "bun scripts/build-lsp-image.ts",
    "docker:build:code": "bun scripts/build-code-image.ts",
    "docker:cleanup": "bun scripts/cleanup-containers.ts",
    "verify:v1:two-user": "bun scripts/verify-v1-two-user.ts",
    "verify:v1:three-user": "bun scripts/verify-v1-three-user-smoke.ts",
    "measure": "bun scripts/measure-resources.ts",
    "backup": "bun scripts/backup.ts",
    "restore": "bun scripts/restore.ts",
    "migrate": "bun apps/control/src/migrate.ts apply",
    "migrate:status": "bun apps/control/src/migrate.ts status",
    "typecheck": "bun scripts/typecheck.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
