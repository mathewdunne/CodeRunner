{
  "name": "frc-programming-training-sim",
  "private": true,
  "version": "1.0.0-v1.0",
  "description": "V1 rewrite scaffold for the FRC Web Simulator.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:control": "bun apps/control/src/main.ts",
    "dev:web": "bun --cwd apps/web run dev",
    "typecheck": "bun scripts/typecheck.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
