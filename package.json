{
  "name": "frc-programming-training-sim",
  "private": true,
  "version": "0.0.0",
  "description": "Browser-based IDE for learning FRC robot programming. See Project-MVP.md.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build:ascope": "tsx scripts/build-ascope-lite.ts",
    "dev:mvp": "tsx scripts/dev-mvp.ts",
    "dev:server": "npm run dev --workspace apps/server",
    "serve:ascope": "tsx scripts/serve-ascope-lite.ts",
    "dev:web": "npm run dev --workspace apps/web",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@fastify/static": "^8.0.4",
    "@types/node": "^22.10.0",
    "fastify": "^5.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
