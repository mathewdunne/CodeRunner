    {"id": "dec005_java_lsp", "label": "Decision 005: Java LSP MVP Integration", "file_type": "document", "source_file": "docs/decisions/005-java-lsp.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "rationale_headless_sim", "label": "Rationale: Headless sim via omission (no SimGUI/DriverStation)", "file_type": "rationale", "source_file": "docs/decisions/001-sim-container.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GradleRIO 2026 makes SimGUI and DriverStation sim opt-in; removing those lines from build.gradle avoids needing an X server or DISPLAY env var."},
    {"id": "rationale_aslite_hostname", "label": "Rationale: AS Lite reads window.location.hostname for NT4", "file_type": "rationale", "source_file": "docs/decisions/002-advantagescope-lite-hosting.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When ASCOPE_DISTRIBUTION=LITE, AS Lite hardcodes window.location.hostname:5810 for NT4, so serving on localhost:8080 with sim on localhost:5810 works with zero source patches."},
    {"id": "rationale_custom_ws", "label": "Rationale: Custom WebSocket sender without @fastify/websocket", "file_type": "rationale", "source_file": "docs/decisions/004-backend-wiring.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The /run socket is server-to-client text streaming only; the backend implements WebSocket handshake and unmasked text frames directly on Node HTTP upgrade event, avoiding a dependency."},
    {"id": "rationale_plain_monaco_lsp", "label": "Rationale: Plain Monaco client with direct LSP requests instead of TypeFox wrappers", "file_type": "rationale", "source_file": "docs/decisions/005-java-lsp.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "TypeFox MonacoVscodeApiWrapper caused unreliable browser behavior; a small direct LSP adapter in java-lsp.ts is simpler and more debuggable for MVP scope."},
    {"id": "rationale_no_coep", "label": "Rationale: No Cross-Origin-Embedder-Policy headers (AS Lite iframe)", "file_type": "rationale", "source_file": "docs/decisions/005-java-lsp.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Adding COEP caused Chrome to reject the AS Lite iframe from localhost:8080, so cross-origin isolation headers were deliberately left off the Vite dev server."},
    {"id": "rationale_ascope_iframe", "label": "Rationale: AS Lite embedded via iframe, not bundled into web app", "file_type": "rationale", "source_file": "docs/decisions/003-web-shell.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "iframe sandboxes AS Lite's WebGL/wasm/asset loading, avoids coupling build pipelines, and auto-connects to NT4 via window.location.hostname."},
    {"id": "rationale_tini_pid1", "label": "Rationale: tini as PID 1 in sim container to reap zombie processes", "file_type": "rationale", "source_file": "docs/decisions/004-backend-wiring.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Without an init reaper, stopped sim PIDs remained as zombies and caused every rebuild to wait for the 10-second hard-kill path."},
    {"id": "rationale_single_stage_dockerfile", "label": "Rationale: Single-stage Dockerfile to preserve Gradle cache", "file_type": "rationale", "source_file": "docs/decisions/001-sim-container.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-stage builds would lose ~/.gradle/caches; baking the cache in a single stage is necessary so container startup does not re-download WPILib jars."},
    {"id": "concept_nt4_routing_multitenancy", "label": "NT4 Routing under Multi-Tenancy (spike question)", "file_type": "rationale", "source_file": "Spike-Multi-Tenancy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AS Lite hardcodes window.location.hostname:5810; multi-tenant options include port-per-user, subdomain-per-user, WS proxy demux by path, or patching AS Lite to read endpoint from URL param."},
    {"id": "concept_shared_jdtls", "label": "Shared vs. Per-user JDT LS topology (spike question)", "file_type": "rationale", "source_file": "Spike-Multi-Tenancy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Eclipse JDT LS supports multiple workspaces in one process. Shared instance saves ~1.5 GB RAM per student if it works with correct per-browser routing and failure isolation."}
  ],
