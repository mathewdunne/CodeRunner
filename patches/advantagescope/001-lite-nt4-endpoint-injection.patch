+}
+
+const frcSimEndpointMode = new URLSearchParams(window.location.search).get("frcEndpoint") === "postMessage";
+
+function isFrcSimEndpoint(input: unknown): input is FrcSimNt4Endpoint {
+  if (input === null || typeof input !== "object") return false;
+  let endpoint = input as { aliveUrl?: unknown; websocketUrl?: unknown };
+  return (
+    typeof endpoint.aliveUrl === "string" &&
+    endpoint.aliveUrl.length > 0 &&
+    typeof endpoint.websocketUrl === "string" &&
+    endpoint.websocketUrl.length > 0
+  );
+}
+
+function showFrcSimNoEndpointBanner() {
+  if (window.frcSimNt4Endpoint !== undefined) return;
+  let banner = document.createElement("div");
+  banner.style.cssText =
