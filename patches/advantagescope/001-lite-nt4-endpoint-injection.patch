+    frcSimStartLivePending = false;
+    sendMessage(hubPort, "start-live", false);
+  }
+}
+
+function installFrcSimEndpointHandshake() {
+  if (!frcSimEndpointMode) return;
+
+  frcSimEndpointTimeoutId = window.setTimeout(showFrcSimNoEndpointBanner, 10_000);
+
+  window.addEventListener("message", (event) => {
+    let message = event.data as { type?: unknown; endpoint?: unknown } | null;
+    if (message?.type !== "frc-sim:set-nt4-endpoint" || !isFrcSimEndpoint(message.endpoint)) return;
+
+    if (frcSimEndpointTimeoutId !== null) {
+      window.clearTimeout(frcSimEndpointTimeoutId);
+      frcSimEndpointTimeoutId = null;
+    }
+
+    window.frcSimNt4Endpoint = message.endpoint;
+    window.parent.postMessage(
+      {
+        type: "frc-sim:nt4-endpoint-ready"
+      },
+      event.origin.length > 0 ? event.origin : "*"
+    );
+    requestFrcSimLiveStart();
+  });
+}
+
+installFrcSimEndpointHandshake();

