+  banner.textContent =
+    "AdvantageScope Lite did not receive an endpoint configuration from the parent app within 10 seconds.";
+  document.body.appendChild(banner);
+}
+
+function requestFrcSimLiveStart() {
+  if (!frcSimEndpointMode || window.frcSimNt4Endpoint === undefined) return;
+  if (hubPort === null) {
+    frcSimStartLivePending = true;
